<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trips</title>
</head>
<body>
    <%- include('../partials/navbar') %>
    <h1>All Trips</h1>
    <% for (let oneTrip of trips){ %>
    
        <p><%= oneTrip.title %></p>
        <p><%= oneTrip.photo %></p>

        <a href="/trip/<%= oneTrip._id %>">Show Trip details</a>
    <% } %>    
</body>
</html>