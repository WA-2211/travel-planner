<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Destinations</title>
</head>
<body>
    <h1>All Destinations</h1>
    <% for(let oneDestination of destinations) { %>
        <p>Trip: <%= oneDestination.trip.title %> </p>
        <p>Destination: <%= oneDestination.country %>, <%= oneDestination.city %></p>

    <% } %>
</body>
</html>