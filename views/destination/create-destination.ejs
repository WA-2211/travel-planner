<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Destination</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="backLink">
        <a href="/home" class="aBack">> Back</a>
    </div>
    <h1>Create Destination</h1>

    <div class="forms">
    <form action="/destination/new" method="post">

        <label for="country">Country:</label>
        <input type="text" name="country" id="country">

        <label for="city">City:</label>
        <input type="text" name="city" id="city">

        <label for="trip">Trip:</label>
        <select name="trip" id="trip">
        <% for (let oneTrip of trips){ %>
            <option value="<%= oneTrip._id %>"><%= oneTrip.title %></option>
          <% } %>
       </select>

        <button type="submit" class="btnSubmit">Create Destination</button>
    </form>
    </div>
    
</body>
</html>